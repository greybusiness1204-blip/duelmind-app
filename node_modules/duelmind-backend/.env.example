# ─────────────────────────────────────────────────────────────────
# DuelMind Backend — Environment Variables
# Copy this file:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────
# Matches docker-compose.yml and the local psql setup in README
DATABASE_URL="postgresql://duelmind:duelmind_secret@localhost:5432/duelmind"

# ─── JWT Secrets ──────────────────────────────────────────────────
# These defaults work for LOCAL development.
# CHANGE THEM before any production deployment.
JWT_SECRET="duelmind-dev-jwt-secret-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="duelmind-dev-refresh-secret-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# ─── File uploads ─────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5

# ─── Anti-cheat ───────────────────────────────────────────────────
MIN_REACTION_MS=100
MAX_SCORE_MULTIPLIER=3
