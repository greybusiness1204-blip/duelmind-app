generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum DuelType {
  TRIVIA
  REACTION
}

enum DuelStatus {
  WAITING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Language {
  en
  az
  ru
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isSuspended  Boolean  @default(false) @map("is_suspended")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile         Profile?
  createdDuels    Duel[]           @relation("DuelCreator")
  joinedDuels     Duel[]           @relation("DuelOpponent")
  questionHistory QuestionHistory[]
  miniGameScores  MiniGameScore[]
  leaderboards    Leaderboard[]
  adminLogs       AdminLog[]
  duelResults     DuelResult[]

  @@map("users")
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  language    Language @default(en)
  totalWins   Int      @default(0) @map("total_wins")
  totalDuels  Int      @default(0) @map("total_duels")
  totalXp     Int      @default(0) @map("total_xp")
  bio         String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  icon      String?
  color     String?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  questions Question[]

  @@map("categories")
}

model Question {
  id            String     @id @default(uuid())
  categoryId    String     @map("category_id")
  familyId      String?    @map("family_id")
  language      Language   @default(en)
  difficulty    Difficulty @default(MEDIUM)
  questionText  String     @map("question_text")
  answerOptions Json       @map("answer_options")
  correctAnswer String     @map("correct_answer")
  explanation   String?
  imageUrl      String?    @map("image_url")
  isActive      Boolean    @default(true) @map("is_active")
  cooldownPlays Int        @default(10) @map("cooldown_plays")
  playCount     Int        @default(0) @map("play_count")
  correctCount  Int        @default(0) @map("correct_count")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  category        Category          @relation(fields: [categoryId], references: [id])
  questionHistory QuestionHistory[]

  @@map("questions")
}

model QuestionHistory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  wasCorrect Boolean  @map("was_correct")
  responseMs Int      @map("response_ms")
  context    String   @default("LEARN")
  answeredAt DateTime @default(now()) @map("answered_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@map("question_history")
}

model Duel {
  id          String     @id @default(uuid())
  creatorId   String     @map("creator_id")
  opponentId  String?    @map("opponent_id")
  type        DuelType   @default(TRIVIA)
  status      DuelStatus @default(WAITING)
  inviteCode  String     @unique @map("invite_code")
  config      Json       @default("{}")
  isQuickMatch Boolean   @default(false) @map("is_quick_match")
  startedAt   DateTime?  @map("started_at")
  endedAt     DateTime?  @map("ended_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  creator  User         @relation("DuelCreator", fields: [creatorId], references: [id])
  opponent User?        @relation("DuelOpponent", fields: [opponentId], references: [id])
  results  DuelResult[]

  @@map("duels")
}

model DuelResult {
  id        String   @id @default(uuid())
  duelId    String   @map("duel_id")
  userId    String   @map("user_id")
  isWinner  Boolean  @default(false) @map("is_winner")
  score     Int      @default(0)
  answers   Json     @default("[]")
  roundsWon Int      @default(0) @map("rounds_won")
  createdAt DateTime @default(now()) @map("created_at")

  duel Duel @relation(fields: [duelId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("duel_results")
}

model MiniGameScore {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  gameType   String   @map("game_type")
  score      Int
  durationMs Int      @map("duration_ms")
  metadata   Json     @default("{}")
  isFlagged  Boolean  @default(false) @map("is_flagged")
  flagReason String?  @map("flag_reason")
  playedAt   DateTime @default(now()) @map("played_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mini_game_scores")
}

model Leaderboard {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  boardType String   @map("board_type")
  score     Int      @default(0)
  rank      Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, boardType])
  @@map("leaderboards")
}

model GameConfig {
  id        String   @id @default(uuid())
  gameType  String   @unique @map("game_type")
  isEnabled Boolean  @default(true) @map("is_enabled")
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("game_configs")
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@map("admin_logs")
}
